# Nova-RAG AI Service Environment Variables

# Aliyun DashScope API (embedding + reranking)
ALIYUN_API_KEY=your_dashscope_api_key_here

# Minimax API Configuration
MINIMAX_API_KEY=your_api_key_here
MINIMAX_GROUP_ID=your_group_id_here

# Database Configuration (PostgreSQL + pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/novarag

# HuggingFace Mirror (for China regions)
HF_ENDPOINT=https://hf-mirror.com

# CORS allowed origins (comma-separated, for production use your frontend domain)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========== RAG Tuning (all optional, shown with defaults) ==========

# Chunker
# CHUNK_PARENT_SIZE=2000
# CHUNK_CHILD_SIZE=500
# CHUNK_OVERLAP=100

# Embedder
# EMBED_MODEL=text-embedding-v3
# EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBED_BATCH_SIZE=6
# EMBED_BATCH_SLEEP=0.1
# EMBED_MAX_TEXT_CHARS=6000

# Retriever
# RECALL_MULTIPLIER=8
# RETRIEVER_TOP_K=8
# RRF_K=40
# MISSING_RANK=1000
# DISTANCE_THRESHOLD=10.0

# Reranker
# RERANK_MODEL=gte-rerank
# RERANK_MIN_SCORE=0.5

# Chat
# MAX_CONTEXT_TOKENS=6000
# MAX_HISTORY_TOKENS=2000

# Query Rewriter
# SHORT_QUERY_THRESHOLD=10
# QUERY_PATTERNS_FILE=  (path to JSON file with custom expansion patterns)
